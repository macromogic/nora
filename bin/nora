#!/usr/bin/env bash
set -euo pipefail

NORA_HOME="${NORA_HOME:-$HOME/nora}"

cmd="${1:-help}"

case "$cmd" in
  help)
    cat <<'EOF'
Nora — personal research workflow system

Commands:
  nora init           Initialize Nora state in the current project
  nora doctor         Check whether the current project has Nora state files
  nora install-skill  Symlink the nora-project-manager skill into Claude Code / Codex
  nora update         Pull the latest nora CLI and skills from git
EOF
    ;;

  update)
    if [ ! -d "$NORA_HOME/.git" ]; then
      echo "NORA_HOME is not a git repository: $NORA_HOME"
      exit 1
    fi

    if [ -n "$(git -C "$NORA_HOME" status --porcelain)" ]; then
      echo "NORA_HOME has uncommitted changes, refusing to update: $NORA_HOME"
      exit 1
    fi

    git -C "$NORA_HOME" pull --ff-only
    ;;

  install-skill)
    src="$NORA_HOME/skills/nora-project-manager"

    if [ ! -d "$src" ]; then
      echo "Skill source not found: $src"
      exit 1
    fi

    installed_any=0

    if [ -d "$HOME/.claude" ]; then
      mkdir -p "$HOME/.claude/skills"
      ln -sfn "$src" "$HOME/.claude/skills/nora-project-manager"
      ln -sfn "$src" "$HOME/.claude/skills/nora"
      echo "Installed for Claude Code: $HOME/.claude/skills/nora-project-manager (alias: /nora)"
      installed_any=1
    fi

    if [ -d "$HOME/.codex" ]; then
      mkdir -p "$HOME/.codex/skills"
      ln -sfn "$src" "$HOME/.codex/skills/nora-project-manager"
      ln -sfn "$src" "$HOME/.codex/skills/nora"
      echo "Installed for Codex: $HOME/.codex/skills/nora-project-manager (alias: nora)"
      installed_any=1
    fi

    if [ "$installed_any" -eq 0 ]; then
      echo "No ~/.claude or ~/.codex directory found. Nothing installed."
      exit 1
    fi

    echo "Restart your agent session to pick up the new skill."
    ;;

  init)
    if [ -d ".nora" ]; then
      echo "Nora state already exists: .nora/"
      exit 0
    fi

    mkdir -p .nora

    cp "$NORA_HOME/skills/nora-project-manager/templates/AGENTS.md" ./AGENTS.md
    cp -r "$NORA_HOME/skills/nora-project-manager/templates/.nora/"* ./.nora/

    echo "Initialized Nora project state in:"
    echo "  $(pwd)/.nora"
    ;;

  doctor)
    echo "Checking Nora project state..."

    missing=0

    for f in \
      ".nora/PROJECT_STATE.yaml" \
      ".nora/CONTEXT_BRIEF.md" \
      ".nora/SESSION_LOG.md" \
      ".nora/NEXT_ACTIONS.md" \
      ".nora/OPEN_LOOPS.md"
    do
      if [ -f "$f" ]; then
        echo "OK: $f"
      else
        echo "MISSING: $f"
        missing=1
      fi
    done

    if [ "$missing" -eq 0 ]; then
      echo "Nora project state looks OK."
    else
      echo "Some Nora files are missing."
      exit 1
    fi
    ;;

  *)
    echo "Unknown command: $cmd"
    echo "Run: nora help"
    exit 1
    ;;
esac