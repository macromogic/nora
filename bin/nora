#!/usr/bin/env python3
"""Thin launcher for the Nora CLI; the implementation lives in src/nora_cli.

This file must stay parseable by very old interpreters (no f-strings, no
new syntax) so the version gate below can print a clean error instead of
the interpreter dying on a SyntaxError.
"""

import sys

if sys.version_info < (3, 8):
    sys.stderr.write(
        "nora requires Python 3.8+ (found %s.%s)\n" % sys.version_info[:2]
    )
    sys.exit(1)

from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from nora_cli.cli import main

if __name__ == "__main__":
    sys.exit(main())
